<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/AdminCss.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>

<div class="layout">

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="brand">
            <h2>Hello admin</h2>
        </div>

        <nav>
            <ul>
                <li><a href="/admin" class="active">Dashboard</a></li>
                <li><a href="/admin/add">+ Add Jobs</a></li>
                <li><a href="/admin/show">View Posts</a></li>
                <li><a href="/">View Website</a></li>
            </ul>
        </nav>
    </aside>

    <!-- Main Content -->
    <div class="main">

        <!-- Topbar -->
        <header class="topbar">
            <h1>Dashboard Overview</h1>
            <div class="admin-profile">
                <div class="avatar">A</div>
                <span>Admin</span>
            </div>
        </header>

        <!-- Stats Section -->
        <section class="stats">

            <div class="stat-card">
                <h3>Total Jobs</h3>
                <p>120</p>
                <span>+12 this week</span>
            </div>

            <div class="stat-card">
                <h3>Total Applications</h3>
                <p>540</p>
                <span>+30 today</span>
            </div>

            <div class="stat-card">
                <h3>Active Listings</h3>
                <p>87</p>
                <span>Currently Live</span>
            </div>

        </section>

        <!-- Action Cards -->
        <section class="actions">

            <div class="action-card">
                <h3>Create New Job</h3>
                <p>Add a new job opportunity for candidates.</p>
                <a href="/admin/add" class="btns">Add Job</a>
            </div>

            <div class="action-card">
                <h3>Manage Posts</h3>
                <p>Edit, delete or manage job listings.</p>
                <a href="/admin/show" class="btns">View Posts</a>
            </div>

            <div class="action-card">
                <h3>Visit Website</h3>
                <p>Preview public website interface.</p>
                <a href="/" class="btns">Open Website</a>
            </div>

        </section>

    </div>
</div>

</body>
</html>