<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/AdminCss.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
<%
const stats = typeof dashboardStats !== 'undefined' && dashboardStats ? dashboardStats : {};
%>

<div class="layout">

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="brand">
            <h2>Hello <%= currentAdmin?.username || 'Admin' %></h2>
        </div>

        <nav>
            <ul>
                <li><a href="/admin" class="active">Dashboard</a></li>
                <li><a href="/admin/add">+ Add Jobs</a></li>
                <li><a href="/admin/show">View Posts</a></li>
                <li><a href="/">View Website</a></li>
            </ul>
        </nav>
    </aside>

    <!-- Main Content -->
    <div class="main">

        <!-- Topbar -->
        <header class="topbar">
            <h1>Dashboard Overview</h1>
            <div class="admin-profile">
                <div class="avatar"><%= (currentAdmin?.username[0]).toUpperCase() || 'A' %></div>
                <span><%= currentAdmin?.username || 'Admin' %></span>
                <form action="/admin/logout" method="POST" class="ms-2">
                    <button class="btn btn-sm btn-outline-light" type="submit">Logout</button>
                </form>
            </div>
        </header>

        <% if (success && success.length) { %>
            <div class="alert alert-success"><%= success[0] %></div>
        <% } %>

        <% if (error && error.length) { %>
            <div class="alert alert-danger"><%= error[0] %></div>
        <% } %>

        <!-- Stats Section -->
        <section class="stats">

            <div class="stat-card">
                <h3>Total Jobs</h3>
                <p><%= stats.totalJobs || 0 %></p>
                <span>+<%= stats.jobsThisWeek || 0 %> this week</span>
            </div>

            <div class="stat-card">
                <h3>Total Vacancies</h3>
                <p><%= stats.totalVacancies || 0 %></p>
                <span>Across all posts</span>
            </div>

            <div class="stat-card">
                <h3>Active Listings</h3>
                <p><%= stats.activeListings || 0 %></p>
                <span>Currently Live</span>
            </div>

        </section>

        <!-- Action Cards -->
        <section class="actions">

            <div class="action-card">
                <h3>Create New Job</h3>
                <p>Add a new job opportunity for candidates.</p>
                <a href="/admin/add" class="btns">Add Job</a>
            </div>

            <div class="action-card">
                <h3>Manage Posts</h3>
                <p>Edit, delete or manage job listings.</p>
                <a href="/admin/show" class="btns">View Posts</a>
            </div>

            <div class="action-card">
                <h3>Visit Website</h3>
                <p>Preview public website interface.</p>
                <a href="/" class="btns">Open Website</a>
            </div>

        </section>

    </div>
</div>

</body>
</html>