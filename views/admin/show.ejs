<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>⚡ Admin • View Posts</title>

<!-- Bootstrap 5 -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/AdminCss.css">
</head>

<body class="bg-light">
<div class="layout">
<aside class="sidebar">
        <div class="brand">
            <h2>⚡ AdminPro</h2>
        </div>

        <nav>
            <ul>
                <li><a href="/admin" >Dashboard</a></li>
                <li><a href="/admin/add" >+ Add Jobs</a></li>
                <li><a href="/admin/show" class="active">View Posts</a></li>
                <li><a href="/">View Website</a></li>
            </ul>
        </nav>
    </aside>
  <!-- Main Content -->
  <main class="flex-fill p-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="fw-bold">All Job Posts</h3>
      <span class="badge bg-primary fs-6">
        Total: <%= allposts.length %>
      </span>
    </div>

    <!-- Search Box -->
    <div class="mb-4">
      <input type="text" class="form-control" placeholder="Search job title...">
    </div>

    <!-- Posts List -->
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">

        <ul class="list-group list-group-flush">

          <% for(let post of allposts){ %>

          <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap">

            <!-- Left Side -->
            <div>
              <h6 class="mb-1 fw-semibold">
                <%= post.title %>
              </h6>

              <small class="text-muted">
                Posted on:
                <%= new Date(post.createdAt).toLocaleDateString() %>
              </small>
            </div>

            <!-- Right Side Buttons -->
            <div class="mt-2 mt-md-0">

              <a href="/jobs/<%= post._id %>" 
                  class="btn btn-sm btn-outline-secondary">
                  View
              </a>

              <a href="/admin/edit/<%= post._id %>" 
                  class="btn btn-sm btn-warning">
                  Update
              </a>

              <form action="/admin/delete/<%= post._id %>?_method=DELETE"
                    method="POST"
                    class="d-inline">
                <button class="btn btn-sm btn-danger">
                  Delete
                </button>
              </form>

            </div>

          </li>

          <% } %>

        </ul>

      </div>
    </div>

    <!-- If No Posts -->
    <% if(allposts.length === 0){ %>
      <div class="alert alert-info text-center mt-4">
        No posts available.
      </div>
    <% } %>

  </main>

</div>

</body>
</html>