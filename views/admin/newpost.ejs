<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
  <title>Admin • Add Job</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/AdminCss.css">

</head>
<body>
<%
const d = formData || {};
%>

<!-- <div class="d-flex"> -->
<div class="layout">
<aside class="sidebar">
        <div class="brand">
            <h2>Hello admin</h2>
        </div>

        <nav>
            <ul>
                <li><a href="/admin" >Dashboard</a></li>
                <li><a href="/admin/add" class="active">+ Add Jobs</a></li>
                <li><a href="/admin/show">View Posts</a></li>
                <li><a href="/">View Website</a></li>
                <li>
                  <form action="/admin/logout" method="POST" class="mt-3">
                    <button class="btn btn-sm btn-outline-light w-100" type="submit">Logout</button>
                  </form>
                </li>
            </ul>
        </nav>
    </aside>

<!-- Main -->
 <div class="main">
<!-- <main class="flex-fill p-4 bg-light"> -->

<div class="container-fluid">

<div class="card shadow-lg border-0 rounded-4">
<div class="card-header bg-primary text-white rounded-top-4">
  <h5 class="mb-0">Add New Job</h5>
</div>

<div class="card-body p-4">
<% if (success && success.length) { %>
  <div class="alert alert-success"><%= success[0] %></div>
<% } %>

<% if (error && error.length) { %>
  <div class="alert alert-danger"><%= error[0] %></div>
<% } %>

<form method="POST" action="/admin">

<!-- ================= BASIC INFO ================= -->

<h5 class="section-title">Basic Information</h5>
<div class="row g-3">

<div class="col-md-6">
<label class="form-label">Job Title</label>
<input type="text" name="Job[title]" class="form-control" value="<%= d.title || '' %>">
</div>

<div class="col-md-6">
<label class="form-label">Category</label>
<select name="Job[category]" class="form-select">
<option value="latest_job" <%= d.category === 'latest_job' ? 'selected' : '' %>>Latest Job</option>
<option value="admit_card" <%= d.category === 'admit_card' ? 'selected' : '' %>>Admit Card</option>
<option value="result" <%= d.category === 'result' ? 'selected' : '' %>>Result</option>
</select>
</div>

<div class="col-md-6">
<label class="form-label">Job Type</label>
<select name="Job[jobType]" class="form-select">
<option value="central">Central</option>
<option value="state">State</option>
</select>
</div>

<div class="col-md-6">
<label class="form-label">Apply Mode</label>
<select name="Job[applyMode]" class="form-select">
<option value="online">Online</option>
<option value="offline">Offline</option>
</select>
</div>
<br>
<div class="col-md-8">
<input type="text" placeholder="enter job Location" name="Job[jobLocation]" class="form-control">
</div>
<div class="col-md-3 mt-3">
  <button class="btn btn-success" id="addlocationbtn">Add More Location</button>
</div>
<div class="joblocation">

</div>
<div class="col-md-6">
<label class="form-label">Salary</label>
<input type="text" name="Job[salary]" class="form-control">
</div>

</div>

<hr class="my-4">

<!-- ================= IMPORTANT DATES ================= -->
<h5 class="section-title">Important Dates</h5>
<div class="row g-3">

<div class="col-md-4"><label class="form-label">Start Date</label>
<input type="date" name="Job[importantDates][startDate]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Last Date</label>
<input type="date" name="Job[importantDates][lastDate]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Correction Date</label>
<input type="date" name="Job[importantDates][correctionDate]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Exam City Date</label>
<input type="date" name="Job[importantDates][examCityDate]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Admit Card Date</label>
<input type="date" name="Job[importantDates][admitCardDate]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Exam Date</label>
<input type="date" name="Job[importantDates][examDate]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Result Date</label>
<input type="date" name="Job[importantDates][resultDate]" class="form-control"></div>

</div>

<hr class="my-4">

<!-- ================= APPLICATION FEES ================= -->
<h5 class="section-title">Application Fees</h5>
<div class="row g-3">

<div class="col-md-2"><label class="form-label">General</label>
<input type="number" name="Job[applicationFee][general]" class="form-control"></div>

<div class="col-md-2"><label class="form-label">OBC</label>
<input type="number" name="Job[applicationFee][obc]" class="form-control"></div>

<div class="col-md-2"><label class="form-label">SC</label>
<input type="number" name="Job[applicationFee][sc]" class="form-control"></div>

<div class="col-md-2"><label class="form-label">ST</label>
<input type="number" name="Job[applicationFee][st]" class="form-control"></div>

<div class="col-md-2"><label class="form-label">EWS</label>
<input type="number" name="Job[applicationFee][ews]" class="form-control"></div>

<div class="col-md-2"><label class="form-label">Female</label>
<input type="number" name="Job[applicationFee][female]" class="form-control"></div>

<div class="col-12">
  <button class="btn btn-success" id="refundfeeBtn">Add refund</button>
</div>
</div>
<div class="refunddiv row g-3">

</div>


<hr class="my-4">

<!-- ================= AGE LIMIT ================= -->
<h5 class="section-title">Age Limit</h5>
<div class="row g-3">

<div class="col-md-4"><label class="form-label">Minimum Age</label>
<input type="number" name="Job[ageLimit][min]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Maximum Age</label>
<input type="number" name="Job[ageLimit][max]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Age As On</label>
<input type="date" name="Job[ageLimit][asOnDate]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Age Relaxation</label>
<input type="text" name="Job[ageLimit][relaxation]" class="form-control"></div>

</div>

<hr class="my-4">

<!-- ================= VACANCY ================= -->
<h5 class="section-title">Vacancy Details</h5>
<div class="row g-3">

<div class="col-md-4"><label class="form-label">Qualification</label>
<input type="text" name="Job[posts][qualification]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Post Name</label>
<input type="text" name="Job[posts][postName]" class="form-control"></div>

<div class="col-md-4"><label class="form-label">Total Vacancy</label>
<input type="number" name="Job[posts][totalVacancy]" class="form-control"></div>

</div>

<hr class="my-4">
<!-- --------------------------------------------------- -->
<h5 class="section-title">zone wise post/post wise seats</h5>
<div class="row g-3 ">
  <div class="col-md-2">  
    <input class="form-control" type="text"  placeholder="zone/post name" name="Job[zoneVacancies][0][zone]">
</div>
<div class="col-md-2">  
  <input type="number" class="form-control" placeholder="gen" name="Job[zoneVacancies][0][general]">
  </div>
  <div class="col-md-2">
  <input type="number"  class="form-control" placeholder="ews" name="Job[zoneVacancies][0][ews]">
  </div>
   <div class="col-md-2">
  <input type="number" class="form-control" placeholder="obc" name="Job[zoneVacancies][0][obc]">
  </div>
   <div class="col-md-1">
  <input type="number" class="form-control" placeholder="sc" name="Job[zoneVacancies][0][sc]">
  </div>
   <div class="col-md-1">
  <input type="number" class="form-control" placeholder="st" name="Job[zoneVacancies][0][st]">
  </div>
  <div class="col-md-2">
  <button class="btn btn-success" id="zoneaddbtn">add new zone</button>
  </div>
  </div>
  <br>
  <div class="addnewzone row g-3"></div>
  <br>
  <hr class="my-4">
<!-- ------------------------------ -->
<h5 class="section-title">selection process</h5>
<div class="row g-3">
  <div class="col-md-6">
    <input type="text" class="form-control" placeholder="enter step for selection" name="Job[selectionProcess]">
    
</div><div class="col-md-4">
<button class="btn btn-success" id="addNewStep">add new step</button>
</div></div>
<br>
 <div class="stepAddDiv row g-3"></div>
<hr class="my-4">


  <!-- ================================================= -->
    <h5 class="section-title">Exam stages (Optional)</h5>
   <div class="row g-3">

                <!-- Negative Marking -->
                <div class="col-md-6">
                    <label class="form-label">Negative Marking</label>
                    <select class="form-select" name="Job[examStages][0][negativeMarking]">
                        <option value="" selected disabled>Select</option>
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </select>
                </div>

                <!-- Negative Marking Value -->
                <div class="col-md-6">
                    <label class="form-label">Negative Marking Numbers</label>
                    <input type="text" 
                            class="form-control" 
                            placeholder="Enter numbers"
                            name="Job[examStages][0][negativeMarkingvalue]">
                </div>

                <!-- Exam Stage Name -->
                <div class="col-md-6">
                    <label class="form-label">Exam Stage Name</label>
                    <input type="text" 
                            class="form-control" 
                            placeholder="Eg: Shift-1"
                            name="Job[examStages][0][name]">
                </div>

                <!-- Exam Date -->
                <div class="col-md-6">
                    <label class="form-label">Exam Date</label>
                    <input type="date" 
                            class="form-control"
                            name="Job[examStages][0][examDate]">
                </div>

                <!-- Admit Card Date -->
                <div class="col-md-6">
                    <label class="form-label">Admit Card Download Date</label>
                    <input type="date" 
                            class="form-control"
                            name="Job[examStages][0][admitCardDate]">
                </div>
                <!-- Answer Key Link -->
                <div class="col-md-6">
                    <label class="form-label">Answer Key Link</label>
                    <input type="text" 
                            class="form-control"
                            placeholder="Answer key download link"
                            name="Job[examStages][0][answerKeyLink]">
                </div>
                <!-- Result Link -->
                <div class="col-md-6">
                    <label class="form-label">Result Link</label>
                    <input type="text" 
                            class="form-control"
                            placeholder="Result download link"
                            name="Job[examStages][0][resultLink]">
                </div>
                <!-- Notice PDF -->
                <div class="col-md-6">
                    <label class="form-label">Notice PDF Link</label>
                    <input type="text" 
                            class="form-control"
                            placeholder="Notice PDF download link"
                            name="Job[examStages][0][noticePDF]">
                </div>
            </div><br><br>
            <div class="newstageadd row g-3"></div><br>
            <div class="row g-3">
            <div class="col-12">
              <button class="btn btn-success" id="newstagebtn">Add New Stage</button>
            </div>
            </div>
          <hr class="my-4">
          <!-- ------------------------------- -->
<h5 class="section-title">paper pattern (Optional)</h5>
          <div class="row g-3">
    <!-- Subject Name -->
    <div class="col-md-6">
        <label class="form-label">Subject Name</label>
        <input type="text"
               class="form-control"
               name="Job[paperPattern][0][subject]"
               placeholder="Enter Subject Name">
    </div>

    <!-- Questions -->
    <div class="col-md-6">
        <label class="form-label">Number of Questions</label>
        <input type="text"
               class="form-control"
               name="Job[paperPattern][0][questions]"
               placeholder="Enter Subject Questions">
    </div>

    <!-- Marks -->
    <div class="col-md-6">
        <label class="form-label">Total Marks</label>
        <input type="text"
               class="form-control"
               name="Job[paperPattern][0][marks]"
               placeholder="Enter Subject Marks">
    </div>

    <!-- Duration -->
    <div class="col-md-6">
        <label class="form-label">Duration</label>
        <input type="text"
                class="form-control"
                name="Job[paperPattern][0][duration]"
                placeholder="Enter Subject Duration">
    </div>
</div>
<div class="row g-3">
  <div class="row g-3 newsubject">
  </div> 
<br>
    <div class="row g-3">
  <div class="col-md-6">
    <button class="btn btn-success" id="newsubBtn">add new subject</button>
    </div></div>
  <hr class="my-4">

<!-- ================= IMPORTANT LINKS ================= -->
<h5 class="section-title">Important Links</h5>
<div class="row g-3">

<div class="col-md-6"><label class="form-label">Apply Online</label>
<input type="url" name="Job[importantLinks][applyOnline]" class="form-control"></div>

<div class="col-md-6"><label class="form-label">Official Website</label>
<input type="url" name="Job[importantLinks][officialWebsite]" class="form-control"></div>

<div class="col-md-6"><label class="form-label">Notification PDF</label>
<input type="url" name="Job[importantLinks][notificationPDF]" class="form-control"></div>

<div class="col-md-6"><label class="form-label">Answer Key</label>
<input type="url" name="Job[importantLinks][answerKeyLink]" class="form-control"></div>

</div>

<div class="text-end mt-5">
<button type="submit" class="btn btn-primary px-5">Save Job</button>
</div>

</form>

</div>
</div>

</div>
</main>
</div>
<script src="/js/script.js"></script>
</body>
</html>