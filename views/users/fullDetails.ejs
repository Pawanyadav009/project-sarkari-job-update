        </a>
      <% }) %>
    </div>
  </div> -->

  <div class="contentBox mt-3">
    <div class="contentTitle">
      <%= selectedTitle %> (Total: <%= selectedPosts.length %>)
    </div>

    <div class="postArea">
      <% if (selectedPosts.length) { %>
        <ul>
          <% selectedPosts.forEach((post) => { %>
            <li>
              <a class="postLink" href="/jobs/<%= post._id %>"><%= post.title %></a>
              <div class="postDate">
                Updated :
                <%= post.createdAt
                  ? new Date(post.createdAt).toLocaleDateString("en-IN", { day: "2-digit", month: "2-digit", year: "numeric" })
                  : "-" %>
              </div>
              <hr />
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <div class="noPosts">No posts found for this category.</div>
      <% } %>
    </div>
  </div>
</div>