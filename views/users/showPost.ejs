<% layout("layouts/boilerplate") %>
<%
  const p = postData || {};
  const has = (v) =>
    v !== undefined &&
    v !== null &&
    v !== "" &&
    !(Array.isArray(v) && v.length === 0) &&
    !(typeof v === "object" && !Array.isArray(v) && Object.keys(v || {}).length === 0);

  const fmtDate = (d) => {
    try {
      if (!d) return "";
      const dt = new Date(d);
      if (Number.isNaN(dt.getTime())) return "";
      return dt.toLocaleDateString("en-IN", { day: "2-digit", month: "short", year: "numeric" });
    } catch (e) {
      return "";
    }
  };

  const joinArr = (a) => (Array.isArray(a) ? a.filter(Boolean).join(", ") : "");

  const importantDates = p.importantDates || {};
  const applicationFee = p.applicationFee || {};
  const ageLimit = p.ageLimit || {};
  const posts = p.posts || {};
  const importantLinks = p.importantLinks || {};

  const importantDatesRows = [
    ["Application Begin", fmtDate(importantDates.startDate)],
    ["Last Date for Apply Online", fmtDate(importantDates.lastDate)],
    ["Correction Date", fmtDate(importantDates.correctionDate)],
    ["Exam City Date", fmtDate(importantDates.examCityDate)],
    ["Admit Card Available", fmtDate(importantDates.admitCardDate)],
    ["Exam Date", fmtDate(importantDates.examDate)],
    ["Result Date", fmtDate(importantDates.resultDate)],
  ].filter(([, v]) => has(v));

  const feeRows = [
    ["General / OBC", applicationFee.general ?? applicationFee.obc],
    ["EWS", applicationFee.ews],
    ["SC / ST", applicationFee.sc ?? applicationFee.st],
    ["Female", applicationFee.female],
  ].filter(([, v]) => has(v));

  const quickInfoRows = [
    ["Post Name", posts.postName],
    ["Total Vacancy", posts.totalVacancy],
    ["Qualification", posts.qualification],
    ["Category", p.category],
    ["Job Type", p.jobType],
    ["Apply Mode", p.applyMode],
    ["Salary", p.salary],
    ["Job Location", joinArr(p.jobLocation)],
  ].filter(([, v]) => has(v));

  const hasAnyContent =
    has(p.title) ||
    importantDatesRows.length ||
    feeRows.length ||
    quickInfoRows.length ||
    has(ageLimit.min) ||
    has(ageLimit.max) ||
    has(ageLimit.asOnDate) ||
    has(ageLimit.relaxation) ||
    (Array.isArray(p.zoneVacancies) && p.zoneVacancies.length) ||
    (Array.isArray(p.selectionProcess) && p.selectionProcess.length) ||
    (Array.isArray(p.examStages) && p.examStages.length) ||
    (Array.isArray(p.paperPattern) && p.paperPattern.length) ||
    Object.keys(importantLinks).some((k) => has(importantLinks[k]));
%>

<style>
  /* Page wrapper inside a single outer div */
  .pageWrapper { padding: 10px 10px 24px; }

  /* Bordered layout */
  .contentBox {
    border: 2px solid #0b0b0b;
    background: #fff;
  }

  .blueBar {
    background: #0b56d6;
    color: #fff;
    font-weight: 800;
    text-align: center;
    padding: 10px 12px;
  }

  .pageTitleBar {
    background: #0b56d6;
    color: #fff;
    font-weight: 900;
    text-align: center;
    padding: 10px 12px;
    border: 2px solid #0b0b0b;
    border-left: 0;
    border-right: 0;
  }

  .headlineRed {
    color: #d10b0b;
    font-weight: 800;
    text-align: center;
  }

  .mutedText { color: #6c757d; }

  .dataTable td, .dataTable th { vertical-align: middle; }
  .keyValueTable td:first-child { width: 46%; font-weight: 700; }

  .sectionTitleBar {
    background: #0b56d6;
    color: #fff;
    font-weight: 900;
    text-align: center;
    padding: 8px 10px;
    border: 2px solid #0b0b0b;
    border-left: 0;
    border-right: 0;
    margin-top: 14px;
  }

  /* Summary row like screenshot (4 columns) */
  .summaryTable th {
    background: #f7f7f7;
    font-weight: 800;
    text-align: center;
  }
  .summaryTable td {
    text-align: center;
    font-weight: 700;
  }

  .breakLink { word-break: break-word; }
</style>

<div class="pageWrapper">
  <% if (!hasAnyContent) { %>
    <div class="alert alert-warning mb-0">
      Post data not found.
    </div>
  <% } else { %>
    <div class="contentBox">
      <div class="pageTitleBar">
        <%= has(p.title) ? p.title : "Post Details" %>
      </div>

      <div class="p-2 p-md-3">
        <div class="row g-3">
          <div class="col-12">

            <div class="headlineRed mb-2">
              <% if (has(p.title)) { %>
                <span><%= p.title %></span>
              <% } %>
              <% if (has(p.createdAt)) { %>
                <span class="mutedText fw-semibold"> (Updated: <%= fmtDate(p.createdAt) %>)</span>
              <% } %>
            </div>

            <%
              // Screenshot-like 4-column summary (render only cells that have data)
              const summaryCells = [
                { label: "Form Mode", value: p.applyMode },
                { label: "Job State", value: joinArr(p.jobLocation) },
                { label: "Total Posts", value: posts.totalVacancy },
                { label: "Job Type", value: p.jobType },
              ].filter((c) => has(c.value));
            %>

            <% if (summaryCells.length) { %>
              <div class="table-responsive mb-3">
                <table class="table table-bordered mb-0 dataTable summaryTable">
                  <thead>
                    <tr>
                      <% summaryCells.forEach((c) => { %>
                        <th><%= c.label %></th>
                      <% }) %>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <% summaryCells.forEach((c) => { %>
                        <td><%= c.value %></td>
                      <% }) %>
                    </tr>
                  </tbody>
                </table>
              </div>
            <% } %>

            <% if (quickInfoRows.length) { %>
              <div class="sectionTitleBar">Basic Details</div>
              <div class="table-responsive">
                <table class="table table-bordered mb-0 dataTable keyValueTable">
                  <tbody>
                    <% quickInfoRows.forEach(([k, v]) => { %>
                      <tr>
                        <td><%= k %></td>
                        <td><%= v %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>

    <% if (importantDatesRows.length) { %>
      <div class="sectionTitleBar">Important Dates</div>
      <div class="table-responsive">
        <table class="table table-bordered mb-0 dataTable keyValueTable">
          <tbody>
            <% importantDatesRows.forEach(([k, v]) => { %>
              <tr>
                <td><%= k %></td>
                <td><%= v %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <%
      const refund = applicationFee?.refund || {};
      const refundRows = [
        ["Refund (General)", refund.general],
        ["Refund (OBC)", refund.obc],
        ["Refund (EWS)", refund.ews],
        ["Refund (SC)", refund.sc],
        ["Refund (ST)", refund.st],
      ].filter(([, v]) => has(v));
    %>
    <% if (feeRows.length || refundRows.length) { %>
      <div class="sectionTitleBar">Application Fee</div>

      <% if (feeRows.length) { %>
        <div class="table-responsive mb-2">
          <table class="table table-bordered mb-0 dataTable keyValueTable">
            <tbody>
              <% feeRows.forEach(([k, v]) => { %>
                <tr>
                  <td><%= k %></td>
                  <td><%= v %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <% if (refundRows.length) { %>
        <div class="table-responsive">
          <table class="table table-bordered mb-0 dataTable keyValueTable">
            <tbody>
              <% refundRows.forEach(([k, v]) => { %>
                <tr>
                  <td><%= k %></td>
                  <td><%= v %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    <% } %>

    <% if (has(ageLimit.min) || has(ageLimit.max) || has(ageLimit.asOnDate) || has(ageLimit.relaxation)) { %>
      <div class="sectionTitleBar">Age Limit</div>
      <div class="table-responsive">
        <table class="table table-bordered mb-0 dataTable keyValueTable">
          <tbody>
            <% if (has(ageLimit.min)) { %>
              <tr><td>Minimum Age</td><td><%= ageLimit.min %></td></tr>
            <% } %>
            <% if (has(ageLimit.max)) { %>
              <tr><td>Maximum Age</td><td><%= ageLimit.max %></td></tr>
            <% } %>
            <% if (has(ageLimit.asOnDate)) { %>
              <tr><td>Age As on</td><td><%= fmtDate(ageLimit.asOnDate) %></td></tr>
            <% } %>
            <% if (has(ageLimit.relaxation)) { %>
              <tr><td>Age Relaxation</td><td><%= ageLimit.relaxation %></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (has(posts.postName) || has(posts.qualification) || has(posts.totalVacancy)) { %>
      <div class="sectionTitleBar">Posts Details</div>
      <div class="table-responsive">
        <table class="table table-bordered mb-0 dataTable keyValueTable">
          <tbody>
            <% if (has(posts.postName)) { %>
              <tr><td>Post Name</td><td><%= posts.postName %></td></tr>
            <% } %>
            <% if (has(posts.qualification)) { %>
              <tr><td>Qualification</td><td><%= posts.qualification %></td></tr>
            <% } %>
            <% if (has(posts.totalVacancy)) { %>
              <tr><td>Total Vacancy</td><td><%= posts.totalVacancy %></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (Array.isArray(p.zoneVacancies) && p.zoneVacancies.length) { %>
      <div class="sectionTitleBar">Zone-wise Vacancy Details</div>
      <div class="table-responsive">
        <table class="table table-bordered mb-0 dataTable">
          <thead class="table-light">
            <tr>
              <th>Zone</th>
              <th>General</th>
              <th>EWS</th>
              <th>OBC</th>
              <th>SC</th>
              <th>ST</th>
            </tr>
          </thead>
          <tbody>
            <% p.zoneVacancies.forEach((z) => { %>
              <tr>
                <td><%= has(z?.zone) ? z.zone : "-" %></td>
                <td><%= has(z?.general) ? z.general : "-" %></td>
                <td><%= has(z?.ews) ? z.ews : "-" %></td>
                <td><%= has(z?.obc) ? z.obc : "-" %></td>
                <td><%= has(z?.sc) ? z.sc : "-" %></td>
                <td><%= has(z?.st) ? z.st : "-" %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (Array.isArray(p.selectionProcess) && p.selectionProcess.length) { %>
      <div class="sectionTitleBar">Selection Process</div>
      <div class="table-responsive">
        <table class="table table-bordered mb-0 dataTable">
          <thead class="table-light">
            <tr><th>Step</th></tr>
          </thead>
          <tbody>
            <% p.selectionProcess.filter(Boolean).forEach((s) => { %>
              <tr><td><%= s %></td></tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (Array.isArray(p.examStages) && p.examStages.length) { %>
      <div class="sectionTitleBar">Exam Stages</div>
      <div class="table-responsive">
        <table class="table table-bordered mb-0 dataTable">
          <thead class="table-light">
            <tr>
              <th>Stage Name</th>
              <th>Exam Date</th>
              <th>Admit Card Date</th>
              <th>Negative Marking</th>
              <th>Negative Marking Value</th>
              <th>Notice PDF</th>
              <th>Answer Key</th>
              <th>Result</th>
            </tr>
          </thead>
          <tbody>
            <% p.examStages.forEach((stg, idx) => { %>
              <%
                const stageName = has(stg?.name) ? stg.name : `Stage ${idx + 1}`;
                const examDate = fmtDate(stg?.examDate);
                const admitDate = fmtDate(stg?.admitCardDate);
              %>
              <tr>
                <td><%= stageName %></td>
                <td><%= has(examDate) ? examDate : "-" %></td>
                <td><%= has(admitDate) ? admitDate : "-" %></td>
                <td><%= has(stg?.negativeMarking) ? stg.negativeMarking : "-" %></td>
                <td><%= has(stg?.negativeMarkingvalue) ? stg.negativeMarkingvalue : "-" %></td>
                <td>
                  <% if (has(stg?.noticePDF)) { %>
                    <a class="breakLink" href="<%= stg.noticePDF %>" target="_blank" rel="noopener noreferrer">Open</a>
                  <% } else { %>-<% } %>
                </td>
                <td>
                  <% if (has(stg?.answerKeyLink)) { %>
                    <a class="breakLink" href="<%= stg.answerKeyLink %>" target="_blank" rel="noopener noreferrer">Open</a>
                  <% } else { %>-<% } %>
                </td>
                <td>
                  <% if (has(stg?.resultLink)) { %>
                    <a class="breakLink" href="<%= stg.resultLink %>" target="_blank" rel="noopener noreferrer">Open</a>
                  <% } else { %>-<% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <% if (Array.isArray(p.paperPattern) && p.paperPattern.length) { %>
      <div class="sectionTitleBar">Paper Pattern</div>
      <div class="table-responsive">
        <table class="table table-bordered mb-0 dataTable">
          <thead class="table-light">
            <tr>
              <th>Subject</th>
              <th>Questions</th>
              <th>Marks</th>
              <th>Duration</th>
            </tr>
          </thead>
          <tbody>
            <% p.paperPattern.forEach((pp) => { %>
              <tr>
                <td><%= has(pp?.subject) ? pp.subject : "-" %></td>
                <td><%= has(pp?.questions) ? pp.questions : "-" %></td>
                <td><%= has(pp?.marks) ? pp.marks : "-" %></td>
                <td><%= has(pp?.duration) ? pp.duration : "-" %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <%
      const linkRows = [
        ["Apply Online", importantLinks.applyOnline],
        ["Official Website", importantLinks.officialWebsite],
        ["Notification PDF", importantLinks.notificationPDF],
        ["Answer Key", importantLinks.answerKeyLink],
      ].filter(([, v]) => has(v));
    %>
    <% if (linkRows.length) { %>
      <div class="sectionTitleBar">Important Links</div>
      <div class="table-responsive">
        <table class="table table-bordered mb-0 dataTable keyValueTable">
          <tbody>
            <% linkRows.forEach(([label, url]) => { %>
              <tr>
                <td><%= label %></td>
                <td><a class="breakLink" href="<%= url %>" target="_blank" rel="noopener noreferrer"><%= url %></a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

            <div class="mt-3 small mutedText">
              <% if (has(p._id)) { %>
                Post ID: <%= p._id %>
              <% } %>
            </div>

          </div>

        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <% } %>
</div>