<% layout("layouts/boilerplate") %>
<%
  const p = postData || {};

  const hasValue = (v) =>
    v !== undefined &&
    v !== null &&
    v !== "" &&
    !(Array.isArray(v) && v.length === 0) &&
    !(typeof v === "object" && !Array.isArray(v) && Object.keys(v || {}).length === 0);

  const formatDate = (d) => {
    try {
      if (!d) return "";
      const date = new Date(d);
      if (Number.isNaN(date.getTime())) return "";
      return date.toLocaleDateString("en-IN", { day: "2-digit", month: "2-digit", year: "numeric" });
    } catch (e) {
      return "";
    }
  };

  const formatText = (value) => {
    if (!hasValue(value)) return "";
    return String(value).replace(/_/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
  };

  const joinText = (arr) => Array.isArray(arr) ? arr.filter(Boolean).join(", ") : "";
  const makeList = (items) => items.filter((item) => hasValue(item.value));

  const importantDates = p.importantDates || {};
  const applicationFee = p.applicationFee || {};
  const refund = applicationFee.refund || {};
  const ageLimit = p.ageLimit || {};
  const posts = p.posts || {};
  const importantLinks = p.importantLinks || {};
  const zoneVacancies = Array.isArray(p.zoneVacancies) ? p.zoneVacancies.filter(Boolean) : [];
  const selectionProcess = Array.isArray(p.selectionProcess) ? p.selectionProcess.filter(Boolean) : [];
  const examStages = Array.isArray(p.examStages) ? p.examStages.filter(Boolean) : [];
  const paperPattern = Array.isArray(p.paperPattern) ? p.paperPattern.filter(Boolean) : [];

  const titleText = hasValue(p.title) ? p.title : "Post Details";
  const locationText = joinText(p.jobLocation);
  const totalPostsText = hasValue(posts.totalVacancy) ? `${posts.totalVacancy} Posts` : "";

  const summaryCells = makeList([
    { label: "Form Mode", value: formatText(p.applyMode) },
    { label: "Job State", value: locationText || "All India" },
    { label: "Total Posts", value: totalPostsText },
    { label: "Job Type", value: formatText(p.jobType) }
  ]);

  const shortDetails = makeList([
    { label: "Category", value: formatText(p.category) },
    { label: "Post Name", value: posts.postName },
    { label: "Qualification", value: posts.qualification },
    { label: "Salary", value: p.salary },
    { label: "Updated On", value: formatDate(p.createdAt) }
  ]);

  const importantDateLines = makeList([
    { label: "Application Begin", value: formatDate(importantDates.startDate) },
    { label: "Last Date", value: formatDate(importantDates.lastDate) },
    { label: "Correction Date", value: formatDate(importantDates.correctionDate) },
    { label: "Exam City Date", value: formatDate(importantDates.examCityDate) },
    { label: "Admit Card Date", value: formatDate(importantDates.admitCardDate) },
    { label: "Exam Date", value: formatDate(importantDates.examDate) },
    { label: "Result Date", value: formatDate(importantDates.resultDate) }
  ]);

  const feeLines = makeList([
    { label: "General", value: applicationFee.general },
    { label: "OBC", value: applicationFee.obc },
    { label: "SC", value: applicationFee.sc },
    { label: "ST", value: applicationFee.st },
    { label: "EWS", value: applicationFee.ews },
    { label: "Female", value: applicationFee.female },
    { label: "Refund General", value: refund.general },
    { label: "Refund OBC", value: refund.obc },
    { label: "Refund EWS", value: refund.ews },
    { label: "Refund SC", value: refund.sc },
    { label: "Refund ST", value: refund.st }
  ]);

  const ageLines = makeList([
    { label: "Minimum Age", value: hasValue(ageLimit.min) ? `${ageLimit.min} Years` : "" },
    { label: "Maximum Age", value: hasValue(ageLimit.max) ? `${ageLimit.max} Years` : "" },
    { label: "Age As On", value: formatDate(ageLimit.asOnDate) },
    { label: "Age Relaxation", value: ageLimit.relaxation }
  ]);

  const postLines = makeList([
    { label: "Post Name", value: posts.postName },
    { label: "Qualification", value: posts.qualification },
    { label: "Total Vacancy", value: posts.totalVacancy }
  ]);

  const linkLines = makeList([
    { label: "Apply Online", value: importantLinks.applyOnline },
    { label: "Official Website", value: importantLinks.officialWebsite },
    { label: "Notification PDF", value: importantLinks.notificationPDF },
    { label: "Answer Key", value: importantLinks.answerKeyLink }
  ]);

  const hasAnyContent =
    hasValue(titleText) ||
    summaryCells.length ||
    shortDetails.length ||
    importantDateLines.length ||
    feeLines.length ||
    ageLines.length ||
    postLines.length ||
    zoneVacancies.length ||
    selectionProcess.length ||
    examStages.length ||
    paperPattern.length ||
    linkLines.length;
%>

<style>
  .jobPageWrapper {
    padding: 8px 8px 24px;
  }
  .jobCard {
    max-width: 980px;
    margin: 0 auto;
    background: #fff;
    border: 2px solid #0b0b0b;
  }
  .jobTitleBar {
    background: #0b56d6;
    color: #fff;
    text-align: center;
    font-weight: 900;
    padding: 8px 12px;
    font-size: 1.15rem;
  }
  .jobIntro {
    text-align: center;
    padding: 10px 14px 14px;
    border-bottom: 1px solid #cfcfcf;
  }
  .jobIntroHeading {
    color: #d10b0b;
    font-weight: 800;
    font-size: 1rem;
    margin-bottom: 4px;
  }
  .jobIntroText {
    line-height: 1.6;
    font-size: 1.05rem;
  }
  .summaryTable,
  .detailTable {
    margin-bottom: 0;
  }
  .summaryTable th,
  .summaryTable td,
  .detailTable th,
  .detailTable td {
    border: 1px solid #0b0b0b !important;
    padding: 10px 8px;
    text-align: center;
    vertical-align: middle;
  }
  .summaryTable th,
  .detailTable th {
    background: #f5f5f5;
    font-weight: 800;
  }
  .summaryTable th {
    color: #8b0000;
  }
  .summaryTable td {
    font-weight: 700;
  }
  .sectionBar {
    background: #0b56d6;
    color: #fff;
    text-align: center;
    font-weight: 900;
    padding: 7px 10px;
    font-size: 0.95rem;
  }
  .sectionBody {
    padding: 10px 16px 6px;
    border-bottom: 1px solid #cfcfcf;
  }
  .detailsList {
    margin: 0;
    padding-left: 20px;
  }
  .detailsList li {
    margin-bottom: 7px;
    font-size: 0.95rem;
  }
  .labelStrong {
    font-weight: 700;
  }
  .inlineLink {
    color: #1b46ff;
    font-weight: 700;
    text-decoration: none;
    word-break: break-word;
  }
  .inlineLink:hover {
    text-decoration: underline;
  }
  .mutedText {
    color: #6c757d;
  }
</style>

<div class="jobPageWrapper">
  <% if (!hasAnyContent) { %>
    <div class="alert alert-warning mb-0">Post data not found.</div>
  <% } else { %>
    <div class="jobCard">
      <div class="jobTitleBar"><%= titleText %></div>

      <div class="jobIntro">
        <div class="jobIntroHeading"><%= posts.postName || titleText %></div>
        <div class="jobIntroText">
          Get complete details about <span class="labelStrong"><%= titleText %></span>, including important dates, application fees, age limit, selection process, vacancy and more.
        </div>
      </div>

      <% if (summaryCells.length) { %>
        <div class="table-responsive">
          <table class="table summaryTable">
            <thead>
              <tr>
                <% summaryCells.forEach((cell) => { %>
                  <th><%= cell.label %></th>
                <% }) %>
              </tr>
            </thead>
            <tbody>
              <tr>
                <% summaryCells.forEach((cell) => { %>
                  <td><%= cell.value %></td>
                <% }) %>
              </tr>
            </tbody>
          </table>
        </div>
      <% } %>

      <% if (shortDetails.length) { %>
        <div class="sectionBar">Short Details</div>
        <div class="sectionBody">
          <ul class="detailsList">
            <% shortDetails.forEach((item) => { %>
              <li><span class="labelStrong"><%= item.label %> :</span> <%= item.value %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (importantDateLines.length) { %>
        <div class="sectionBar">Important Dates</div>
        <div class="sectionBody">
          <ul class="detailsList">
            <% importantDateLines.forEach((item) => { %>
              <li><span class="labelStrong"><%= item.label %> :</span> <%= item.value %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (feeLines.length) { %>
        <div class="sectionBar">Application Fees</div>
        <div class="sectionBody">
          <ul class="detailsList">
            <% feeLines.forEach((item) => { %>
              <li><span class="labelStrong"><%= item.label %> :</span> <%= item.value %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (ageLines.length) { %>
        <div class="sectionBar">Age Limit Details</div>
        <div class="sectionBody">
          <ul class="detailsList">
            <% ageLines.forEach((item) => { %>
              <li><span class="labelStrong"><%= item.label %> :</span> <%= item.value %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (postLines.length) { %>
        <div class="sectionBar">Post Details</div>
        <div class="sectionBody">
          <ul class="detailsList">
            <% postLines.forEach((item) => { %>
              <li><span class="labelStrong"><%= item.label %> :</span> <%= item.value %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (selectionProcess.length) { %>
        <div class="sectionBar">Selection Process</div>
        <div class="sectionBody">
          <ul class="detailsList">
            <% selectionProcess.forEach((step) => { %>
              <li><%= step %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (zoneVacancies.length) { %>
        <div class="sectionBar">Zone Wise Vacancy Details</div>
        <div class="table-responsive">
          <table class="table detailTable">
            <thead>
              <tr>
                <th>Zone</th>
                <th>General</th>
                <th>EWS</th>
                <th>OBC</th>
                <th>SC</th>
                <th>ST</th>
              </tr>
            </thead>
            <tbody>
              <% zoneVacancies.forEach((zone) => { %>
                <tr>
                  <td><%= zone.zone || "-" %></td>
                  <td><%= hasValue(zone.general) ? zone.general : "-" %></td>
                  <td><%= hasValue(zone.ews) ? zone.ews : "-" %></td>
                  <td><%= hasValue(zone.obc) ? zone.obc : "-" %></td>
                  <td><%= hasValue(zone.sc) ? zone.sc : "-" %></td>
                  <td><%= hasValue(zone.st) ? zone.st : "-" %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <% if (examStages.length) { %>
        <div class="sectionBar">Exam Stages</div>
        <div class="sectionBody">
          <ul class="detailsList">
            <% examStages.forEach((stage, idx) => { %>
              <li>
                <span class="labelStrong"><%= stage.name || `Stage ${idx + 1}` %></span>
                <ul class="detailsList mt-2">
                  <% if (hasValue(stage.examDate)) { %>
                    <li><span class="labelStrong">Exam Date :</span> <%= formatDate(stage.examDate) %></li>
                  <% } %>
                  <% if (hasValue(stage.admitCardDate)) { %>
                    <li><span class="labelStrong">Admit Card Date :</span> <%= formatDate(stage.admitCardDate) %></li>
                  <% } %>
                  <% if (hasValue(stage.negativeMarking)) { %>
                    <li><span class="labelStrong">Negative Marking :</span> <%= stage.negativeMarking %></li>
                  <% } %>
                  <% if (hasValue(stage.negativeMarkingvalue)) { %>
                    <li><span class="labelStrong">Negative Marking Value :</span> <%= stage.negativeMarkingvalue %></li>
                  <% } %>
                  <% if (hasValue(stage.noticePDF)) { %>
                    <li><span class="labelStrong">Notice PDF :</span> <a class="inlineLink" href="<%= stage.noticePDF %>" target="_blank" rel="noopener noreferrer">Open Link</a></li>
                  <% } %>
                  <% if (hasValue(stage.answerKeyLink)) { %>
                    <li><span class="labelStrong">Answer Key :</span> <a class="inlineLink" href="<%= stage.answerKeyLink %>" target="_blank" rel="noopener noreferrer">Open Link</a></li>
                  <% } %>
                  <% if (hasValue(stage.resultLink)) { %>
                    <li><span class="labelStrong">Result :</span> <a class="inlineLink" href="<%= stage.resultLink %>" target="_blank" rel="noopener noreferrer">Open Link</a></li>
                  <% } %>
                </ul>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (paperPattern.length) { %>
        <div class="sectionBar">Paper Pattern</div>
        <div class="table-responsive">
          <table class="table detailTable">
            <thead>
              <tr>
                <th>Subject</th>
                <th>Questions</th>
                <th>Marks</th>
                <th>Duration</th>
              </tr>
            </thead>
            <tbody>
              <% paperPattern.forEach((row) => { %>
                <tr>
                  <td><%= row.subject || "-" %></td>
                  <td><%= hasValue(row.questions) ? row.questions : "-" %></td>
                  <td><%= hasValue(row.marks) ? row.marks : "-" %></td>
                  <td><%= row.duration || "-" %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <% if (linkLines.length) { %>
        <div class="sectionBar">Important Links</div>
        <div class="sectionBody">
          <ul class="detailsList">
            <% linkLines.forEach((item) => { %>
              <li><span class="labelStrong"><%= item.label %> :</span> <a class="inlineLink" href="<%= item.value %>" target="_blank" rel="noopener noreferrer"><%= item.value %></a></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (hasValue(p._id)) { %>
        <div class="sectionBody small mutedText">Post ID: <%= p._id %></div>
      <% } %>
    </div>
  <% } %>
</div>