



<% layout("layouts/boilerplate") %>

<%
const posts = allposts || [];

// Flexible Category Filter
function getPosts(categoryName){

    return posts.filter(post =>

        String(post.category || "")
        .trim()
        .toLowerCase()
        .includes(categoryName.toLowerCase())

    );

}

// Categories
const categories = [

    {title:"Latest Job", key:"latest"},
    {title:"Result", key:"result"},
    {title:"Admit Card", key:"admit"},
    {title:"Answer Key", key:"answer"},
    {title:"Offline Form", key:"offline"}

];
%>


<style>

.gridBox{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:2px;
    border:2px solid black;
}

@media(max-width:768px){

.gridBox{
    grid-template-columns:1fr;
}

}

.cardBox{
    border:1px solid black;
    background:#ececec;
}

.cardTitle{
    background:#005dc9;
    color:white;
    font-size:22px;
    font-weight:700;
    text-align:center;
    padding:10px;
}

.postArea{
    padding:10px;
    min-height:350px;
}

.postArea ul{
    padding-left:25px;
}

.postArea li{
    margin-bottom:8px;
}

.postLink{
    color:#123cff;
    font-size:18px;
    font-weight:700;
    text-decoration:none;
}

.postLink:hover{
    text-decoration:underline;
}

.postDate{
    color:red;
    font-size:14px;
    font-weight:700;
    margin-top:3px;
}

.btnWrap{
    text-align:center;
    padding:18px;
}

.viewBtn{
    background:#30379b;
    color:white;
    padding:12px 28px;
    border-radius:5px;
    text-decoration:none;
    font-size:14px;
    font-weight:bold;
}

hr{
    margin:6px 0;
}

</style>



<div class="gridBox">

<% categories.forEach(cat=>{ %>

<%

const catPosts = getPosts(cat.key)

.sort((a,b)=>

    new Date(b.createdAt || 0)
    -
    new Date(a.createdAt || 0)

)

.slice(0,7);

%>


<div class="cardBox">

    <div class="cardTitle">
        <%= cat.title %>
    </div>

    <div class="postArea">

        <ul>

        <% if(catPosts.length){ %>

            <% catPosts.forEach(post=>{ %>

                <li>

                    <a
                    class="postLink"
                    href="/jobs/<%= post._id %>"
                    >

                    <%= post.title %>

                    </a>

                    <div class="postDate">

                        Updated :

                        <%= new Date(post.createdAt)
                        .toLocaleDateString("en-IN",{

                            day:"2-digit",
                            month:"2-digit",
                            year:"numeric"

                        }) %>

                    </div>

                </li>

                <hr>

            <% }) %>

        <% } else { %>

            <p>No posts found</p>

        <% } %>

        </ul>

    </div>

    <div class="btnWrap">

        <a
        class="viewBtn"
        href="#"
        >

        View More

        </a>

    </div>

</div>

<% }) %>

</div>